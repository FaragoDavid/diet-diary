# Database
DB_CONN_STRING=postgresql://developer:secret@localhost:5435/db

# Server Configuration
PORT=3000
HOST=localhost
PUBLIC_ASSETS_PATH=http://localhost:3000

# Security Secrets (change these in production!)
COOKIE_SECRET=cookie_secret_change_me
SESSION_SECRET=session_secret_change_me

# Google OAuth Configuration (Backend - being phased out)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI: http://localhost:3000/auth/google/callback
# 3. Copy credentials below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=your.email@gmail.com

# Firebase Configuration (Client - new)
# Get these values from your Firebase Console > Project Settings
# https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=diet-diary-ca28e.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=diet-diary-ca28e
# VITE_FIREBASE_STORAGE_BUCKET=diet-diary-ca28e.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
