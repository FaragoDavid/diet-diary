{
  "name": "diet-diary",
  "author": "Faragó Dávid",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/server",
    "start:dev": "npx nodemon dist/server",
    "css": "npx tailwindcss -i ./css/input.css -o ./public/output.css --watch",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest -i",
    "test:unit:watch": "jest --watch -i",
    "test:e2e:dev": "cypress open",
    "test:e2e": "cypress run"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/formbody": "8.0.2",
    "@fastify/oauth2": "8.1.1",
    "@fastify/session": "11.0.1",
    "@fastify/static": "9.0.0",
    "@prisma/client": "6.19.2",
    "date-fns": "4.1.0",
    "dotenv": "17.2.3",
    "fastify": "5.7.1",
    "html-format": "1.1.7",
    "simply-beautiful": "1.0.1",
    "typed-html": "3.0.1"
  },
  "devDependencies": {
    "@lit-labs/ssr": "4.0.0",
    "@tsconfig/node24": "24.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.10.9",
    "cypress": "15.9.0",
    "daisyui": "5.5.14",
    "jest": "30.2.0",
    "prisma": "6.19.2",
    "tailwindcss": "4.1.18",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  }
}
